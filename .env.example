# RAGfolio environment variables
# Copy to .env.local for local development. On Vercel, set these as project
# env vars. Full reference: README.md → "Environment variables".

# ── Chat provider (required) ─────────────────────────────────────────────────
# Selects the chat model. Fails at boot with a clear error if unset or
# invalid — there is no silent default. "gemini" is the documented default;
# "groq" is the tested alternative (see docs/environment.md).
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini. Get a free key: https://aistudio.google.com/apikey
GEMINI_CHAT_API_KEY=

# Required when LLM_PROVIDER=groq. Get a free key: https://console.groq.com/keys
GROQ_API_KEY=

# ── Embeddings (required) ────────────────────────────────────────────────────
# Embeddings are a separate decision from chat (only Gemini is implemented
# today, regardless of LLM_PROVIDER). Also required at BUILD time: ingest
# embeds the corpus during `npm run build`. Get a free key:
# https://aistudio.google.com/apikey (can be the same key as GEMINI_CHAT_API_KEY,
# or a different project's key — they're independently configurable).
GEMINI_EMBEDDING_API_KEY=

# ── Password gate (optional) ─────────────────────────────────────────────────
# Set BOTH to enable the gate; leave both unset for a public site.
# SITE_PASSWORD_HASH set without SESSION_SECRET fails closed (explicit error —
# the site will not silently go public).
# Base64-encoded bcrypt hash of your site password (base64, not the raw
# bcrypt hash — see src/lib/auth/password-hash.ts for why). Generate one:
#   npm run hash-password -- "your password"
# Paste the printed line as-is; no quoting needed.
SITE_PASSWORD_HASH=
# Secret for signing the session cookie. REQUIRED to be 32+ bytes — shorter
# is rejected at request time (fails closed, same as a missing secret): a
# short HS256 key is brute-forceable, letting an attacker forge a session
# cookie. Generate one: `openssl rand -base64 32`.
SESSION_SECRET=

# ── Tracing (optional) ───────────────────────────────────────────────────────
# When present, LangSmith tracing activates; absent, tracing is a silent no-op.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=

# ── Rate limiting (optional, recommended for public deployments) ─────────────
# When present, the chat endpoint (LLM quota) and /api/auth (~5 attempts/min/IP)
# are rate limited. Absent: NO rate limiting — see the README warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
