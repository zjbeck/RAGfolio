# RAGfolio environment variables
# Copy to .env.local for local development. On Vercel, set these as project
# env vars. Full reference: README.md → "Environment variables".

# ── Required ─────────────────────────────────────────────────────────────────
# Gemini API key — used for chat (gemini-3.5-flash) and embeddings
# (gemini-embedding-2). Also required at BUILD time: ingest embeds the corpus
# during `npm run build`. Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Password gate (optional) ─────────────────────────────────────────────────
# Set BOTH to enable the gate; leave both unset for a public site.
# SITE_PASSWORD_HASH set without SESSION_SECRET fails closed (explicit error —
# the site will not silently go public).
# Base64-encoded bcrypt hash of your site password (base64, not the raw
# bcrypt hash — see src/lib/auth/password-hash.ts for why). Generate one:
#   npm run hash-password -- "your password"
# Paste the printed line as-is; no quoting needed.
SITE_PASSWORD_HASH=
# Secret for signing the session cookie (32+ random bytes, e.g.
# `openssl rand -base64 32`).
SESSION_SECRET=

# ── Tracing (optional) ───────────────────────────────────────────────────────
# When present, LangSmith tracing activates; absent, tracing is a silent no-op.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=

# ── Rate limiting (optional, recommended for public deployments) ─────────────
# When present, the chat endpoint (LLM quota) and /api/auth (~5 attempts/min/IP)
# are rate limited. Absent: NO rate limiting — see the README warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
