# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# build-time ingest artifact (regenerated by `npm run ingest`)
/src/generated/

# build-time theme shim (regenerated by scripts/detect-theme.ts)
/src/styles/theme.generated.css

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
